class Solution {
    public int countPairs(List<Integer> nums, int target) {
        Collections.sort(nums);
        int i = 0, j = nums.size() - 1;
        int cnt = 0;
        while(i < j){
            int sum = nums.get(i) + nums.get(j);
            if(sum < target){
                cnt += j - i;
                i++;
            }else{
                j--;
            }
        }
        return cnt;
    }
}
