class Solution {
    public boolean hasSpecialSubstring(String S, int k) {
        char[] s = S.toCharArray();
        int cnt = 1;
        
        for(int i = 0; i < s.length; i++){
            if(i > 0 && s[i] == s[i - 1]){
                cnt++;                
            }else{
                cnt = 1;
            }

            if(cnt == k && (i + 1 == s.length || (i + 1 < s.length && s[i + 1] != s[i]))){
                return true;
            }
        }
        return false;
    }
}
